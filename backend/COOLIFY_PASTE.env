# Paste into Coolify (or your host) — BACKEND service only.
# Fill every empty value. Then redeploy backend.

# ── Admin UI (/admin signs in with these) ────────────────────
ADMIN_BASIC_AUTH_USER=backend_admin
ADMIN_BASIC_AUTH_PASSWORD=

# ── Internal API (change from placeholder) ───────────────────
INTERNAL_API_KEY=

# ── MaxMind (your existing setup) ───────────────────────────
# Do NOT add MAXMIND_BLOCK_TOR — this app does not read it.
# Do NOT add GEOLITE2_CITY_PATH — use MAXMIND_DB_PATH only if you use a local .mmdb file.
MAXMIND_ENABLED=true
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
MAXMIND_DB_PATH=
MAXMIND_BLOCK_NON_SA=false
MAXMIND_BLOCK_VPN=false
MAXMIND_RISK_SCORE_THRESHOLD=75.0

# ── Optional: IPQuality second opinion (VPN) ────────────────
IPQUALITY_API_KEY=
IPQUALITY_VPN_FRAUD_SCORE_THRESHOLD=85.0

# ── Database (your app already has this) ────────────────────
# DATABASE_URL=postgresql+psycopg://...
