APP_NAME=SKINKSA API
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=change_me
APP_CORS_ORIGINS=https://officialskinksa.store

HOST=0.0.0.0
PORT=8000
RUN_MIGRATIONS_ON_START=true
SEED_ON_START=true

DATABASE_URL=postgresql+psycopg://postgres:password@skinksa_database:5432/skinksa?sslmode=disable

DEFAULT_COUNTRY_CODE=966
DEFAULT_CURRENCY=SAR
ORDER_NUMBER_PREFIX=SK

# Deploy Google Apps Script as Web app (POST); paste the deployment URL here (no secret).
# Sheet1 row 1 (20 cols): OrderDate,orderid,country,name,phone,address,url,sku,Product,quantity,price,currency,status,notes,utm_source,utm_medium,utm_campaign,utm_term,utm_content,national_address
# Script: backend/scripts/google-apps-script/OrdersWebhook.gs — only `status` is left blank on rows.
ORDERS_WEBHOOK_URL=
ORDERS_WEBHOOK_TIMEOUT_SECONDS=10

META_CAPI_ENABLED=true
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

TIKTOK_CAPI_ENABLED=true
TIKTOK_PIXEL_CODE=
TIKTOK_ACCESS_TOKEN=
TIKTOK_TEST_EVENT_CODE=

SNAP_CAPI_ENABLED=true
SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=
SNAP_TEST_EVENT_CODE=

INTERNAL_API_KEY=change_me_internal_key
RATE_LIMIT_ORDERS_PER_MINUTE=20

# ─────────────────────────────────────────────────────────────
# MaxMind GeoIP2
# ─────────────────────────────────────────────────────────────
# Enable / disable the entire GeoIP feature.
# When false, all rules below are ignored and every order is allowed.
MAXMIND_ENABLED=false

# ── Option A: Web Service (recommended for fraud signals) ────
# Sign up at https://www.maxmind.com/en/geolite2/signup
# Use GeoIP2 Insights for is_anonymous_vpn / risk_score.
# Use GeoIP2 City or GeoLite2 for country/city only (no fraud signals).
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# ── Option B: Local MMDB file ────────────────────────────────
# Download GeoLite2-City.mmdb (free) or GeoIP2-City.mmdb (paid).
# Absolute path inside the container, e.g. mount via EasyPanel volume.
# Note: local DB does NOT include fraud signals (is_vpn, risk_score).
# Leave blank to use the web service instead.
MAXMIND_DB_PATH=

# ── Block rules (all default OFF — turn on in prod when ready) ──
# Block orders from outside Saudi Arabia.
MAXMIND_BLOCK_NON_SA=false

# Block orders from detected VPN / open proxy / Tor exit nodes.
# Requires GeoIP2 Insights (web service) — local DB has no signal.
MAXMIND_BLOCK_VPN=false

# Block orders where GeoIP2 Insights risk_score exceeds this value (0–100).
# Set to 0 to disable the risk-score check.
# Requires GeoIP2 Insights subscription.
MAXMIND_RISK_SCORE_THRESHOLD=75.0

# ─────────────────────────────────────────────────────────────
# Optional: IPQualityScore (second opinion for VPN/proxy on analytics + orders)
# https://www.ipqualityscore.com — used only when key is set; failures fail open.
# ─────────────────────────────────────────────────────────────
IPQUALITY_API_KEY=
# If fraud_score >= this, treat as VPN for KPI filtering (0 disables).
IPQUALITY_VPN_FRAUD_SCORE_THRESHOLD=85.0

# ─────────────────────────────────────────────────────────────
# Admin dashboard API (/v1/admin/*) — HTTP Basic auth
# ─────────────────────────────────────────────────────────────
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=
