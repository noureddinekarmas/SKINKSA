APP_NAME=SKINKSA API
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=change_me
APP_CORS_ORIGINS=https://officialskinksa.store

HOST=0.0.0.0
PORT=8000
RUN_MIGRATIONS_ON_START=true
SEED_ON_START=true

DATABASE_URL=postgresql+psycopg://postgres:password@skinksa_database:5432/skinksa?sslmode=disable

DEFAULT_COUNTRY_CODE=966
DEFAULT_CURRENCY=SAR
ORDER_NUMBER_PREFIX=SK

ORDERS_WEBHOOK_URL=
ORDERS_WEBHOOK_TOKEN=
ORDERS_WEBHOOK_TIMEOUT_SECONDS=10

META_CAPI_ENABLED=true
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

TIKTOK_CAPI_ENABLED=true
TIKTOK_PIXEL_CODE=
TIKTOK_ACCESS_TOKEN=
TIKTOK_TEST_EVENT_CODE=

SNAP_CAPI_ENABLED=true
SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=
SNAP_TEST_EVENT_CODE=

INTERNAL_API_KEY=change_me_internal_key
RATE_LIMIT_ORDERS_PER_MINUTE=20
