# Container listen address (required for Docker / EasyPanel)
HOSTNAME=0.0.0.0
# MUST match the "Destination Port" on your domain in EasyPanel (you use 80 there → set 80 here)
PORT=80

# Public site URL (no trailing slash). Use your real domain or subdomain, e.g. https://shop.blueksa
NEXT_PUBLIC_SITE_URL=https://officialskinksa.store
# Optional: hostname only — if set, https://THAT-HOST/ rewrites internally to /products/<slug>
# so the “product link” can be https://shop.blueksa/ (DNS + EasyPanel must route this host here).
# NEXT_PUBLIC_PRODUCT_MARKETING_HOST=shop.blueksa
NEXT_PUBLIC_API_BASE_URL=https://api.officialskinksa.store
NEXT_PUBLIC_DEFAULT_LOCALE=ar
NEXT_PUBLIC_DEFAULT_CURRENCY=SAR

NEXT_PUBLIC_ENABLE_TRACKING=true
NEXT_PUBLIC_DEBUG_TRACKING=false

# Meta (Facebook) Pixel — optional
NEXT_PUBLIC_META_PIXEL_ID=
# TikTok Pixel ID from TikTok Ads Manager → Tools → Events → Web Events → Create Pixel
# Use with NEXT_PUBLIC_ENABLE_TRACKING=true. Captures: PageView (snippet), SPA page views,
# ViewContent, AddToCart, InitiateCheckout, SubmitForm (COD), CompletePayment, upsell events.
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_SNAP_PIXEL_ID=

NEXT_PUBLIC_ENABLE_PLACEHOLDER_CONTENT=true
