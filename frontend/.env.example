# Container listen address (required for Docker / EasyPanel)
HOSTNAME=0.0.0.0
# MUST match the "Destination Port" on your domain in EasyPanel (you use 80 there → set 80 here)
PORT=80

NEXT_PUBLIC_SITE_URL=https://officialskinksa.store
NEXT_PUBLIC_API_BASE_URL=https://api.officialskinksa.store
NEXT_PUBLIC_DEFAULT_LOCALE=ar
NEXT_PUBLIC_DEFAULT_CURRENCY=SAR

NEXT_PUBLIC_ENABLE_TRACKING=true
NEXT_PUBLIC_DEBUG_TRACKING=false

NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_SNAP_PIXEL_ID=

NEXT_PUBLIC_ENABLE_PLACEHOLDER_CONTENT=true
