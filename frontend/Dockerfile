FROM node:20-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci --frozen-lockfile

FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ENV NEXT_TELEMETRY_DISABLED=1

# Next.js inlines `NEXT_PUBLIC_*` at build time. EasyPanel/Coolify must pass these as
# `--build-arg` AND they must be declared here or they are ignored during `npm run build`.
ARG NEXT_PUBLIC_SITE_URL=
ARG NEXT_PUBLIC_API_BASE_URL=
ARG NEXT_PUBLIC_DEFAULT_LOCALE=ar
ARG NEXT_PUBLIC_DEFAULT_CURRENCY=SAR
ARG NEXT_PUBLIC_ENABLE_TRACKING=true
ARG NEXT_PUBLIC_DEBUG_TRACKING=false
ARG NEXT_PUBLIC_META_PIXEL_ID=
ARG NEXT_PUBLIC_TIKTOK_PIXEL_ID=
ARG NEXT_PUBLIC_SNAP_PIXEL_ID=
ARG NEXT_PUBLIC_ENABLE_PLACEHOLDER_CONTENT=true
ARG NEXT_PUBLIC_PRODUCT_MARKETING_HOST=

ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_DEFAULT_LOCALE=$NEXT_PUBLIC_DEFAULT_LOCALE
ENV NEXT_PUBLIC_DEFAULT_CURRENCY=$NEXT_PUBLIC_DEFAULT_CURRENCY
ENV NEXT_PUBLIC_ENABLE_TRACKING=$NEXT_PUBLIC_ENABLE_TRACKING
ENV NEXT_PUBLIC_DEBUG_TRACKING=$NEXT_PUBLIC_DEBUG_TRACKING
ENV NEXT_PUBLIC_META_PIXEL_ID=$NEXT_PUBLIC_META_PIXEL_ID
ENV NEXT_PUBLIC_TIKTOK_PIXEL_ID=$NEXT_PUBLIC_TIKTOK_PIXEL_ID
ENV NEXT_PUBLIC_SNAP_PIXEL_ID=$NEXT_PUBLIC_SNAP_PIXEL_ID
ENV NEXT_PUBLIC_ENABLE_PLACEHOLDER_CONTENT=$NEXT_PUBLIC_ENABLE_PLACEHOLDER_CONTENT
ENV NEXT_PUBLIC_PRODUCT_MARKETING_HOST=$NEXT_PUBLIC_PRODUCT_MARKETING_HOST

ARG GIT_COMMIT=unknown
ENV GIT_COMMIT=${GIT_COMMIT}
RUN echo "GIT_COMMIT=${GIT_COMMIT}" && npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
# Next standalone defaults to PORT=3000; EasyPanel often routes to 80 — set PORT in env to match Domains → Destination Port.
ENV HOSTNAME=0.0.0.0
ENV PORT=3000
RUN addgroup -g 1001 -S nodejs && adduser -S nextjs -u 1001
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
# After standalone so a bundled `public/` inside the tarball cannot replace this tree.
COPY --from=builder --chown=nextjs:nodejs /app/public ./public
USER nextjs
EXPOSE 3000 80
CMD ["node", "server.js"]
